# ─────────────────────────────────────────────
# LinguaFlow Backend — Variables de Entorno
# Copia este archivo a .env y configura tus valores
# ─────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=5000

# Cliente (Frontend URL)
CLIENT_URL=http://localhost:3000

# MongoDB (usa MongoDB Atlas para producción)
MONGO_URI=mongodb://localhost:27017/linguaflow
# Ejemplo Atlas: mongodb+srv://user:pass@cluster.mongodb.net/linguaflow?retryWrites=true&w=majority

# JWT (genera con: openssl rand -base64 64)
JWT_SECRET=tu_super_secreto_jwt_access_token_key_32_chars_minimo
JWT_REFRESH_SECRET=tu_super_secreto_jwt_refresh_token_key_32_chars_minimo
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer - Gmail App Password recomendado)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-16-caracteres
SMTP_FROM_NAME=LinguaFlow
SMTP_FROM_EMAIL=noreply@linguaflow.app

# Web Push Notifications (genera con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=tu_vapid_public_key_aqui
VAPID_PRIVATE_KEY=tu_vapid_private_key_aqui
VAPID_EMAIL=admin@linguaflow.app

# Google Cloud (TTS/STT opcional - alta calidad)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# O usa API keys:
# GOOGLE_TTS_API_KEY=tu_google_tts_key
# GOOGLE_STT_API_KEY=tu_google_stt_key

# Rate limiting (producción)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
